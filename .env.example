# Public URL of this demo (used for metadata, webhooks, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://demo.proofage.xyz

# ProofAge API keys (required). Same key for browser SDK and server-side HMAC signing.
PROOFAGE_API_KEY=pk_live_...
PROOFAGE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_PROOFAGE_API_KEY=pk_live_...

# Defaults baked into the code — only override for local dev or custom deployments:
# NEXT_PUBLIC_PROOFAGE_API_URL=https://proofage.com/api/v1
# NEXT_PUBLIC_PROOFAGE_SDK_URL=https://proofage.com/sdk-build/kyc-loader.js
# PROOFAGE_BASE_URL=https://api.proofage.xyz

# Optional: webhook verification clock skew tolerance (seconds)
PROOFAGE_WEBHOOK_TOLERANCE=300
